// Firestore Security Rules for DMForge
// All writes go through our server (admin SDK bypasses these rules).
// Clients only READ public collections (results for share pages).
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /results/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /agents/{id} {
      allow read: if request.auth != null && resource.data.ownerUid == request.auth.uid;
      allow write: if false;
    }
    match /users/{id} {
      allow read: if request.auth != null && request.auth.uid == id;
      allow write: if false;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
