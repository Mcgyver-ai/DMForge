# DMForge Environment Variables
# Copy this file to .env.local for local development

# ─── Google Gemini LLM ───────────────────────────────────────────────────────
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional: route Gemini traffic through a proxy/gateway (same request shape).
# Cloudflare AI Gateway (request logs, caching, cost analytics):
#   GEMINI_BASE_URL=https://gateway.ai.cloudflare.com/v1/{account_id}/dmforge/google-ai-studio
# Unset = call Google directly.
# GEMINI_BASE_URL=

# ─── Firebase (server-side Admin SDK) ────────────────────────────────────────
# OPTION A — Recommended for cloud/container deployments:
#   Paste the full contents of your firebase-admin.json service account here (as a single-line JSON string)
FIREBASE_SERVICE_ACCOUNT_JSON=

# OPTION B — File path (local dev only):
#   Path to your Firebase service account JSON file
# FIREBASE_SERVICE_ACCOUNT_PATH=./credentials/firebase-admin.json

# The named Firestore database ID (defaults to "dmforge")
FIRESTORE_DATABASE_ID=dmforge

# ─── Firebase (client-side) ──────────────────────────────────────────────────
# Get these from Firebase Console → Project Settings → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Use sk_test_... for staging/development, sk_live_... for production
STRIPE_SECRET_KEY=sk_test_...

# Get this from the Stripe dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Credential encryption (lib/encryption.js) ───────────────────────────────
# Any random string (32+ chars recommended). Hashed to a 32-byte AES-256-GCM
# key used to encrypt connected-channel credentials at rest (email, SMS,
# LinkedIn, GHL). Required before any channel can connect.
ENCRYPTION_KEY=

# Optional, only set during a key rotation: put the *previous* ENCRYPTION_KEY
# value here after replacing ENCRYPTION_KEY with a new one. decrypt() falls
# back to this key for existing ciphertext, so rotating ENCRYPTION_KEY does
# not brick stored credentials. Remove once nothing needs the fallback.
# ENCRYPTION_KEY_PREVIOUS=

# ─── LinkedIn OAuth (channel connect) ────────────────────────────────────────
# Register an app at https://developer.linkedin.com, request the
# r_liteprofile / r_emailaddress / w_member_social scopes, and set the redirect
# to https://www.dmforge.org/api/auth/linkedin/callback. The LinkedIn connect
# flow returns 503 until all three are set.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=https://www.dmforge.org/api/auth/linkedin/callback

# ─── Cron / webhook shared secrets ───────────────────────────────────────────
# Secures GET/POST /api/cron/send-reminders. When set, the endpoint requires
# `Authorization: Bearer <CRON_SECRET>` — add the same value as a GitHub repo
# secret so .github/workflows/cron-reminders.yml can authenticate.
CRON_SECRET=

# Verifies inbound GoHighLevel webhooks (HMAC-SHA256 over the raw body via the
# x-ghl-signature header). Unset = signature check skipped.
GHL_WEBHOOK_SECRET=

# ─── App URL ─────────────────────────────────────────────────────────────────
# The public URL of your deployment (used for Stripe redirect URLs)
NEXT_PUBLIC_BASE_URL=https://dmforge.org

# ─── Vercel AI Gateway (optional, alternate LLM provider) ───────────────────
# https://vercel.com/docs/ai-gateway — Get key: Vercel dashboard → AI Gateway → API Keys
# Not wired into the main chat/chatJSON pipeline (lib/llm.js + Gemini stays default).
# Used by lib/aiGateway.js for multi-provider routing / experimentation.
AI_GATEWAY_API_KEY=
# Optional: override the default model (defaults to openai/gpt-5.4 if unset)
# AI_GATEWAY_MODEL=

# ─── Optional ────────────────────────────────────────────────────────────────
# Allowed cross-origin callers of /api (comma-separated).
# Defaults to https://dmforge.org,https://www.dmforge.org
# CORS_ORIGINS=https://dmforge.org,https://www.dmforge.org
